{
    "info": {
        "_postman_id": "b1b2b3b4-b5b6-4b7b-8b8b-9b9b9b9b9b9b",
        "name": "Blood Donors Management API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Postman collection for Blood Donors Management Backend (Express, Prisma)"
    },
    "item": [
        {
            "name": "Auth - Login",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"body\": {\n    \"email\": \"superadmin@blooddm.com\",\n    \"password\": \"yourpassword\"\n  }\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/src/auth/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "src",
                        "auth",
                        "login"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "// Save token to environment",
                            "var json = pm.response.json();",
                            "if(json.data && json.data.accessToken){",
                            "    pm.environment.set('accessToken', json.data.accessToken);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "Post - Create Post (Blood Donation)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{accessToken}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"type\": \"BLOOD_DONATION\",\n  \"title\": \"Need A+ Blood\",\n  \"contactNumber\": \"+8801711223344\",\n  \"division\": \"Dhaka\",\n  \"district\": \"Dhaka\",\n  \"upazila\": \"Dhanmondi\",\n  \"bloodGroup\": \"A_POSITIVE\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/src/post",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "src",
                        "post"
                    ]
                }
            },
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "exec": [
                            "// Ensure token is set",
                            "if(!pm.environment.get('accessToken')){",
                            "    throw new Error('No access token set. Please login first.');",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "Post - Get All Posts",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{accessToken}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/src/post",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "src",
                        "post"
                    ]
                }
            }
        }
    ],
    "event": [],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000"
        }
    ]
}