// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ================= Enums =================
enum UserRole {
  SUPER_ADMIN
  ADMIN
  HOSPITAL
  ORGANISATION
  USER
}

enum AccountStatus {
  PENDING
  ACTIVE
  BLOCKED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PostType {
  BLOOD_FINDING
  BLOOD_DONATION
  HELPING
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ================= Core User Model =================
model User {
  id            String        @id @default(uuid(7))
  email         String?       @unique
  contactNumber String        @unique
  password      String?
  role          UserRole      @default(USER)
  accountStatus AccountStatus @default(PENDING)

  // Shared Location Details
  division String?
  district String?
  upazila  String?

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 1:1 Relations
  superAdmin   SuperAdmin?
  admin        Admin?
  hospital     Hospital?
  organisation Organisation?
  donorProfile DonorProfile? // For regular users/donors

  // Other Relations
  sessions             Session[]
  posts                Post[]
  bloodDonor           BloodDonor?
  donationsAsReceiver  DonationHistory[]        @relation("ReceiverHistory")
  requestedByHospitals HospitalRequest[]        @relation("HospitalRequests")
  organisationManaged  OrganisationVolunteer[]  @relation("OrganisationVolunteers")
  hospitalRecords      HospitalDonationRecord[] @relation("HospitalRecords")
  notifications        Notification[]
  payments             Payment[]
}

// ================= 1:1 Role Models =================
model SuperAdmin {
  id        String   @id @default(uuid(7))
  name      String
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        String   @id @default(uuid(7))
  name      String
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hospital {
  id                 String   @id @default(uuid(7))
  name               String
  registrationNumber String?  @unique
  address            String?
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  isDeleted          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Organisation {
  id                 String   @id @default(uuid(7))
  name               String
  registrationNumber String?  @unique
  establishedYear    String?
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  isDeleted          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DonorProfile {
  id                     String    @id @default(uuid(7))
  name                   String
  bloodGroup             String
  gender                 Gender
  weight                 Float?
  lastDonationDate       DateTime?
  isAvailableForDonation Boolean   @default(true)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ================= Auth & Sessions =================
model Session {
  id     String @id @default(uuid(7))
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Storing email & contact snapshot
  email         String?
  contactNumber String

  refreshToken String  @unique
  device       String?
  ipAddress    String?

  isValid   Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ================= Business Logic Models =================
model BloodDonor {
  id               String    @id @default(uuid(7))
  name             String
  contactNumber    String    @unique
  bloodGroup       String
  gender           Gender
  lastDonationDate DateTime?
  isAvailable      Boolean   @default(true)
  division         String
  district         String
  upazila          String

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  donations        DonationHistory[]
  hospitalRequests HospitalRequest[]
  hospitalRecords  HospitalDonationRecord[]
  organisationVols OrganisationVolunteer[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HospitalDonationRecord {
  id           String     @id @default(uuid(7))
  hospitalId   String
  hospital     User       @relation("HospitalRecords", fields: [hospitalId], references: [id])
  bloodDonorId String
  bloodDonor   BloodDonor @relation(fields: [bloodDonorId], references: [id])
  donationDate DateTime   @default(now())
  weight       Float?
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Post {
  id       String   @id @default(uuid(7))
  authorId String
  author   User     @relation(fields: [authorId], references: [id])
  type     PostType
  content  String
  images   String[] @default([])

  bloodGroup   String?
  division     String?
  district     String?
  upazila      String?
  requiredDate DateTime?

  isApproved   Boolean @default(true)
  isResolved   Boolean @default(false)
  targetAmount Float?
  raisedAmount Float?  @default(0)

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  payments  Payment[]
}

model DonationHistory {
  id                   String     @id @default(uuid(7))
  bloodDonorId         String
  bloodDonor           BloodDonor @relation(fields: [bloodDonorId], references: [id])
  receiverOrgId        String?
  receiverOrg          User?      @relation("ReceiverHistory", fields: [receiverOrgId], references: [id])
  donationDate         DateTime
  weightDuringDonation Float?
  isDeleted            Boolean    @default(false)
  createdAt            DateTime   @default(now())
}

model OrganisationVolunteer {
  id             String        @id @default(uuid(7))
  organisationId String
  organisation   User          @relation("OrganisationVolunteers", fields: [organisationId], references: [id])
  bloodDonorId   String
  bloodDonor     BloodDonor    @relation(fields: [bloodDonorId], references: [id])
  status         RequestStatus @default(PENDING)
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@unique([organisationId, bloodDonorId])
}

model HospitalRequest {
  id           String        @id @default(uuid(7))
  hospitalId   String
  hospital     User          @relation("HospitalRequests", fields: [hospitalId], references: [id])
  bloodDonorId String
  bloodDonor   BloodDonor    @relation(fields: [bloodDonorId], references: [id])
  status       RequestStatus @default(PENDING)
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(uuid(7))
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model VerificationToken {
  id        String   @id @default(uuid(7))
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Payment {
  id            String   @id @default(uuid())
  amount        Float
  status        String   @default("PENDING") // PENDING, SUCCESS, FAILED, CANCELLED
  transactionId String   @unique
  postId        String
  post          Post     @relation(fields: [postId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}